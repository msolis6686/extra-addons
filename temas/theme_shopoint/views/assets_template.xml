    <template id="theme_customize" inherit_id="website.theme_customize">
        <xpath expr="//div" position="replace">
            <div>
                <content string="Headers" title="Theme Shopoint">
                    <opt data-xmlid="theme_shopoint.sp_header_1" data-icon="/theme_shopoint/static/src/images/customize_panel/header-1.png"/>
                    <opt data-xmlid="theme_shopoint.sp_header_2" data-icon="/theme_shopoint/static/src/images/customize_panel/header-2.png"/>
                    <opt data-xmlid="theme_shopoint.sp_header_3" data-icon="/theme_shopoint/static/src/images/customize_panel/header-3.png"/>
                </content>
                <content string="Footers" title="Footers">
                    <opt data-xmlid="theme_shopoint.sp_footer_1,theme_shopoint.sp_footer_custom_1" data-icon="/theme_shopoint/static/src/images/customize_panel/footer-1.png" data-reload='/'/>
                    <opt data-xmlid="theme_shopoint.sp_footer_2,theme_shopoint.sp_footer_custom_2" data-icon="/theme_shopoint/static/src/images/customize_panel/footer-2.png" data-reload='/'/>
                    <opt data-xmlid="theme_shopoint.sp_footer_3,theme_shopoint.sp_footer_custom_3" data-icon="/theme_shopoint/static/src/images/customize_panel/footer-2.png" data-reload='/'/>
                </content>
                <content string="Fonts" title="Theme Shopoint">
                    <opt data-xmlid="theme_shopoint.sp_font_1" string="Nunito"/>
                    <opt data-xmlid="theme_shopoint.sp_font_2" string="Opensans"/>
                    <opt data-xmlid="theme_shopoint.sp_font_3" string="Quicksand"/>
                    <opt data-xmlid="theme_shopoint.sp_font_4" string="Lato"/>
                    <opt data-xmlid="theme_shopoint.sp_font_5" string="Montserrat"/>
                    <opt data-xmlid="theme_shopoint.sp_font_6" string="Raleway"/>
                    <opt data-xmlid="theme_shopoint.sp_font_7" string="Roboto"/>
                    <opt data-xmlid="theme_shopoint.sp_font_8" string="Source Sans"/>
                </content>
                <content string="Color" title="Theme Shopoint">
                    <opt data-xmlid="theme_shopoint.sp_color_1"/>
                    <opt data-xmlid="theme_shopoint.sp_color_2"/>
                    <opt data-xmlid="theme_shopoint.sp_color_3"/>
                    <opt data-xmlid="theme_shopoint.sp_color_4"/>
                    <opt data-xmlid="theme_shopoint.sp_color_5"/>
                    <opt data-xmlid="theme_shopoint.sp_color_6"/>
                    <opt data-xmlid="theme_shopoint.sp_color_7"/>
                    <opt data-xmlid="theme_shopoint.sp_color_8"/>
                    <opt data-xmlid="theme_shopoint.sp_color_9"/>
                    <opt data-xmlid="theme_shopoint.sp_color_10"/>
                    <opt data-xmlid="theme_shopoint.sp_color_11"/>
                    <opt data-xmlid="theme_shopoint.sp_color_12"/>
                    <opt data-xmlid="theme_shopoint.sp_color_13"/>
                    <opt data-xmlid="theme_shopoint.sp_color_14"/>
                    <opt data-xmlid="theme_shopoint.sp_color_15"/>
                    <opt data-xmlid="theme_shopoint.sp_color_16"/>
                </content>
                <content string="Shop Layout">
                    <opt data-xmlid="theme_shopoint.sp_boxed_layout" data-icon="/theme_shopoint/static/src/images/customize_panel/Shop-fix.png" string="Boxed"/>
                    <opt data-xmlid="theme_shopoint.sp_full_layout" data-icon="/theme_shopoint/static/src/images/customize_panel/Shop-full.png" string="Full"/>
                </content>
                <content string="Profile Picture Settings">
                    <opt data-xmlid="theme_shopoint.inherit_portal_layout" data-icon="/theme_shopoint/static/src/images/customize_panel/profile-img.png" data-reload='/'/>
                    <opt data-xmlid="theme_shopoint.core_portal_layout" data-icon="/theme_shopoint/static/src/images/customize_panel/Address.png" data-reload='/'/>
                </content>
            </div>
        </xpath>
    </template>

